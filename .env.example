# Conexão com o banco de dados PostgreSQL (Aiven)
# Troque os valores entre < > pelos dados reais do seu serviço Aiven,
# disponíveis no painel em "Connection information".
# Atenção: use "postgresql+asyncpg://" no início e "?ssl=require" no final
# (NÃO use "sslmode=require", que não funciona com o driver asyncpg).
DATABASE_URL=postgresql+asyncpg://<usuario>:<senha>@<host>:<porta>/<banco>?ssl=require

# Configuração do pool de conexões (opcional, já tem valores padrão no código)
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=5
DB_POOL_RECYCLE=1800